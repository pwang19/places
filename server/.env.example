# Database — see SETUP.md
# DATABASE_URL=...
# PORT=5001

# Google Sign-In (Web client ID from Google Cloud Console)
GOOGLE_CLIENT_ID=

# Signs the HTTP-only session cookie (use a long random string in production)
SESSION_SECRET=

# 32-byte AES key as 64 hex chars (openssl rand -hex 32). Encrypts private place notes at rest.
# PRIVATE_NOTES_KEY=

# Allowed browser origin(s) for CORS (comma-separated for multiple)
CLIENT_ORIGIN=http://localhost:3000

# Only @acts2.network (or this suffix) may sign in
# Comma-separated allowed email domains (optional; matches client VITE_ALLOWED_EMAIL_DOMAIN)
ALLOWED_EMAIL_DOMAIN=acts2.network

# Set to "true" when the API is behind a reverse proxy (HTTPS) so Secure cookies work
# TRUST_PROXY=true

# --- Production (Render, Railway, Fly, etc.) ---
# Set these in the host's environment / secret store, not in git.
#
# CLIENT_ORIGIN=https://your-frontend.example.com
# TRUST_PROXY=true
# DATABASE_URL=postgresql://...   (managed Postgres connection string)
# PORT is usually injected by the platform; omit or match their docs.
#
# Google Cloud Console → APIs & Services → Credentials → your OAuth 2.0 Client ID:
# - Authorized JavaScript origins: https://your-frontend.example.com
# - Authorized redirect URIs: include any redirect URIs your host or Google Sign-In requires
#   (often the same origin or paths your client library uses).
