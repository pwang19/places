# Supabase (required)
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
REACT_APP_SUPABASE_ANON_KEY=

# Google Sign-In — Web client ID (same app as configured in Supabase Auth → Google)
REACT_APP_GOOGLE_CLIENT_ID=

# Optional; Google account-picker hint (client-side domain check after sign-in)
# REACT_APP_ALLOWED_EMAIL_DOMAIN=acts2.network

# --- Legacy Express + cookie API (only if you still run server/ instead of Supabase) ---
# REACT_APP_API_URL=http://localhost:5001/api/v1
