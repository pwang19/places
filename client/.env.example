# Supabase (required)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# Google Sign-In — Web client ID (same app as configured in Supabase Auth → Google)
VITE_GOOGLE_CLIENT_ID=

# Optional; allowed email domain(s), comma-separated (client-side check after sign-in).
# Google Sign-In uses the FIRST domain only for hosted_domain; with multiple domains,
# dev quick-fill uses the LAST (e.g. acts2.network,places.local → Google @acts2.network, dev @places.local).
# VITE_ALLOWED_EMAIL_DOMAIN=acts2.network

# Local dev only: email/password sign-in via Supabase (npm run dev). Do not set in production.
# Requires Email provider enabled in Supabase; dummy emails must use the same domain, e.g.:
# VITE_ALLOWED_EMAIL_DOMAIN=places.local
# VITE_DEV_EMAIL_AUTH=true
